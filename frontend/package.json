        "@angular/router": "21.2.9",
        "@primeng/themes": "^21.0.4",
        "chart.js": "^4.5.1",
        "primeicons": "^7.0.0",
        "primeng": "^21.1.6",
        "rxjs": "~7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular/build": "21.2.9",
